{
  "name": "@mohamedsaba/airlock",
  "version": "0.2.0",
  "description": "Production-ready Transactional Outbox library for NestJS and Node.js. Guarantees at-least-once event delivery with claim-lease mechanics.",
  "author": "Mohamed Saba",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohamedsaba/airlock.git"
  },
  "bugs": {
    "url": "https://github.com/mohamedsaba/airlock/issues"
  },
  "homepage": "https://github.com/mohamedsaba/airlock#readme",
  "keywords": [
    "nestjs",
    "transactional-outbox",
    "microservices",
    "event-driven",
    "postgres",
    "kafka",
    "reliability",
    "distributed-systems",
    "typeorm",
    "skip-locked",
    "prisma",
    "rabbitmq"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "airlock": "./dist/bin/airlock.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "pg": "^8.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0",
    "typeorm": "^0.3.0",
    "kafkajs": "^2.0.0",
    "amqplib": "^0.10.0",
    "@prisma/client": "^5.0.0 || ^6.0.0 || ^7.0.0"
  },
  "peerDependenciesMeta": {
    "kafkajs": {
      "optional": true
    },
    "amqplib": {
      "optional": true
    },
    "typeorm": {
      "optional": true
    },
    "@prisma/client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/testing": "^11.0.1",
    "@types/amqplib": "^0.10.8",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "eslint": "^9.17.0",
    "pg": "^8.13.1",
    "pg-mem": "^2.6.13",
    "prettier": "^3.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "testcontainers": "^10.16.0",
    "typeorm": "^0.3.20",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "kafkajs": "^2.2.4",
    "amqplib": "^1.0.3",
    "prisma": "^7.8.0",
    "@prisma/client": "^7.8.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
